<?xml version="1.0"?>
<robot name="dynamixel_robot">
  <link name="base_link">
    <visual>
      <origin xyz="0.0 0.0 0.075" rpy="0 0 0"/>
      <geometry><box size="0.60 0.30 0.15"/></geometry>
      <material name="grey"><color rgba="0.55 0.55 0.55 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.075" rpy="0 0 0"/>
      <geometry><box size="0.60 0.30 0.15"/></geometry>
    </collision>
    <inertial><mass value="4.0"/>
      <inertia ixx="0.0338" ixy="0" ixz="0" iyy="0.1213" iyz="0" izz="0.1463"/>
    </inertial>
  </link>
  <link name="left_wheel">
    <visual><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.033" length="0.030"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
    </visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.033" length="0.030"/></geometry>
    </collision>
    <inertial><mass value="0.15"/>
      <inertia ixx="0.000041" ixy="0" ixz="0" iyy="0.000081" iyz="0" izz="0.000041"/>
    </inertial>
  </link>
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/><child link="left_wheel"/>
    <origin xyz="0.0 0.085 0.0" rpy="0 0 0"/><axis xyz="0 1 0"/>
  </joint>
  <link name="right_wheel">
    <visual><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.033" length="0.030"/></geometry>
      <material name="black"/>
    </visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.033" length="0.030"/></geometry>
    </collision>
    <inertial><mass value="0.15"/>
      <inertia ixx="0.000041" ixy="0" ixz="0" iyy="0.000081" iyz="0" izz="0.000041"/>
    </inertial>
  </link>
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/><child link="right_wheel"/>
    <origin xyz="0.0 -0.085 0.0" rpy="0 0 0"/><axis xyz="0 1 0"/>
  </joint>
  <link name="front_caster">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.018"/></geometry>
      <material name="lgrey"><color rgba="0.85 0.85 0.85 1.0"/></material>
    </visual>
    <inertial><mass value="0.05"/>
      <inertia ixx="0.000005" ixy="0" ixz="0" iyy="0.000005" iyz="0" izz="0.000005"/>
    </inertial>
  </link>
  <joint name="front_caster_joint" type="fixed">
    <parent link="base_link"/><child link="front_caster"/>
    <origin xyz="0.27 0.0 -0.015" rpy="0 0 0"/>
  </joint>
  <link name="rear_caster">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.018"/></geometry>
      <material name="lgrey"/>
    </visual>
    <inertial><mass value="0.05"/>
      <inertia ixx="0.000005" ixy="0" ixz="0" iyy="0.000005" iyz="0" izz="0.000005"/>
    </inertial>
  </link>
  <joint name="rear_caster_joint" type="fixed">
    <parent link="base_link"/><child link="rear_caster"/>
    <origin xyz="-0.27 0.0 -0.015" rpy="0 0 0"/>
  </joint>
  <link name="laser_frame">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.035" length="0.040"/></geometry>
      <material name="blue"><color rgba="0.1 0.1 0.8 1.0"/></material>
    </visual>
  </link>
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/><child link="laser_frame"/>
    <origin xyz="0.06 0.0 0.15" rpy="0 0 0"/>
  </joint>
</robot>
